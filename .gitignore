# Python bytecode / caches
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Virtual environments
.venv/
venv/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Coverage
.coverage
.coverage.*
htmlcov/
coverage.xml

# cdmon runtime output (the local review log is generated, not source)
.cdmon/

# Generated HTML twins (produced by `cdmon build`; derived-not-edited)
docs/**/*.html

# Dashboard (EPIC-F) frontend build artifacts / deps (the dashboard has its own
# .gitignore too; these mirror it at the root). package-lock.json IS committed.
dashboard/node_modules/
dashboard/dist/
